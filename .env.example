# =========================================================================
# AI Bench — Environment Variables Template
# =========================================================================
# Как использовать:
#   1. cp .env.example .env
#   2. Заполните реальными значениями
#   3. Убедитесь, что .env в .gitignore — никогда не коммитьте ключи
# =========================================================================


# ---------------------------------------------------------------------------
# Yandex Cloud — YandexGPT (текст) + Yandex Vision (картинки)
# ---------------------------------------------------------------------------
# API-ключ сервисного аккаунта.
# Требуемые роли: ai.languageModels.user, ai.vision.user.
# Создаётся в консоли: Сервисные аккаунты → ваш аккаунт → API-ключи.
YANDEX_API_KEY=

# Идентификатор каталога (folder) — b1g..., viewable в консоли рядом с облаком.
# Подставляется в тело запроса: "modelUri": "gpt://<FOLDER_ID>/yandexgpt/..."
YANDEX_FOLDER_ID=

# Endpoint'ы — фиксированные, менять не нужно. Оставлены для отладки/stage.
# Путь (/foundationModels/v1/completion, /vision/v1/batchAnalyze) дописывает провайдер.
# YANDEX_LLM_API_URL=https://llm.api.cloud.yandex.net
# YANDEX_VISION_API_URL=https://vision.api.cloud.yandex.net

# Мок-режим: при YANDEX_MOCK=1 провайдеры yandex-gpt и yandex-vision отвечают
# фикстурой-заглушкой без сетевых запросов. Нужен для CI и локальной разработки
# без ключей. По умолчанию выключен.
# YANDEX_MOCK=


# ---------------------------------------------------------------------------
# Sber GigaChat
# ---------------------------------------------------------------------------
# Authorization Key = base64(client_id:client_secret).
# Используется в заголовке OAuth-запроса токена как:
#   Authorization: Basic <GIGACHAT_AUTH_KEY>
GIGACHAT_AUTH_KEY=

# Scope: GIGACHAT_API_PERS (физлица), GIGACHAT_API_B2B или GIGACHAT_API_CORP.
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Endpoint'ы — фиксированные, менять не нужно.
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1

# TLS: OAuth GigaChat (ngw.devices.sberbank.ru:9443) подписан корневым
# сертификатом Минцифры — Node.js ему по умолчанию не доверяет. Нужно указать
# путь к .pem через стандартную переменную Node:
#   export NODE_EXTRA_CA_CERTS=/abs/path/to/russiantrustedca.pem
# В .env её тоже можно задать, но dotenv загружается ПОСЛЕ инициализации
# undici — безопаснее экспортировать в shell или в .claude/settings.local.json.
# Подробности: providers/README.md, раздел «TLS: сертификат Минцифры».

# Тарифы GigaChat хранятся в providers/gigachat.ts (DEFAULT_PRICING, таблица
# по model). Перекрывать для конкретного прогона — через config.pricing в
# YAML-конфиге Promptfoo. Env-переменной для цены нет умышленно: тариф —
# не секрет и должен жить рядом с кодом.

# Мок-режим: при GIGACHAT_MOCK=1 провайдер gigachat отвечает фикстурой без
# сетевых запросов (OAuth+completion+files skipped). По умолчанию выключен.
# GIGACHAT_MOCK=


# ---------------------------------------------------------------------------
# Qwen — отложен до решения вопроса с оплатой из РФ
# ---------------------------------------------------------------------------
# Когда добавим провайдера, сюда вернутся либо DASHSCOPE_*, либо OPENROUTER_*.


# ---------------------------------------------------------------------------
# Promptfoo
# ---------------------------------------------------------------------------
PROMPTFOO_DISABLE_TELEMETRY=1

# Директория кэша (по умолчанию ~/.promptfoo/cache).
# PROMPTFOO_CACHE_PATH=.promptfoo-cache
