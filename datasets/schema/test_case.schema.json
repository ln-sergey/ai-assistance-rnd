{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "test_case.schema.json",
  "title": "TestCase",
  "description": "Тест-кейс бенчмарка модерации. Два вида: card_case — карточка целиком (текст + опционально IMG-нарушения на метаданных images[i]); image_case — одиночное изображение в контексте привязанной карточки. Разделение нужно, потому что пайплайны текстовой и фото-модерации гоняются из разных конфигов Promptfoo.",
  "oneOf": [
    { "$ref": "#/$defs/card_case" },
    { "$ref": "#/$defs/image_case" }
  ],
  "$defs": {
    "severity": {
      "enum": ["low", "medium", "high", "critical"],
      "description": "Должна строго совпадать с severity правила в rules.yaml. Проверяется дополнительной JS-валидацией — JSON Schema это поле не связывает с rule_id."
    },
    "rule_id_text_or_img": {
      "type": "string",
      "pattern": "^(TXT-(0[1-9]|1[0-9]|2[0-9]|3[0-5])|IMG-(0[1-9]|1[0-9]|2[0-9]|30))$",
      "description": "Идентификатор правила из rules.yaml: TXT-01..TXT-35 или IMG-01..IMG-30."
    },
    "rule_id_img_only": {
      "type": "string",
      "pattern": "^IMG-(0[1-9]|1[0-9]|2[0-9]|30)$",
      "description": "Только IMG-01..IMG-30 — для image_case."
    },
    "field_path_card": {
      "type": "string",
      "pattern": "^[a-z_]+(\\.[a-z_]+|\\[\\d+\\])*$",
      "description": "Путь до поля в карточке в дот-нотации: full_description, program_items[2].description, images[0], contacts_block.public_comment и т.п."
    },
    "field_path_image": {
      "type": "string",
      "pattern": "^images\\[\\d+\\]$",
      "description": "Для image_case — по соглашению images[0], чтобы форма нарушений совпадала с card_case."
    },
    "generator": {
      "type": "object",
      "required": ["date"],
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": ["string", "null"],
          "description": "Какая модель синтезировала кейс (для source=synthetic/hybrid). Для production — null."
        },
        "prompt_version": {
          "type": ["string", "null"],
          "description": "Версия промпта генерации, напр. 'card-gen-v1'. Для production — null."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Дата создания кейса, YYYY-MM-DD."
        }
      }
    },
    "violation_card": {
      "type": "object",
      "required": ["rule_id", "severity", "field_path", "rationale"],
      "additionalProperties": false,
      "properties": {
        "rule_id": { "$ref": "#/$defs/rule_id_text_or_img" },
        "severity": { "$ref": "#/$defs/severity" },
        "field_path": { "$ref": "#/$defs/field_path_card" },
        "quote": {
          "type": ["string", "null"],
          "description": "Фрагмент исходника, где зафиксировано нарушение. Обязателен для TXT-правил (антигаллюцинационный якорь). Для IMG-правил внутри card_case — опционально (только если на фото есть читаемый текст, который и нарушает)."
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "description": "1–2 предложения: почему этот фрагмент нарушает именно это правило."
        }
      }
    },
    "violation_image": {
      "type": "object",
      "required": ["rule_id", "severity", "field_path", "rationale"],
      "additionalProperties": false,
      "properties": {
        "rule_id": { "$ref": "#/$defs/rule_id_img_only" },
        "severity": { "$ref": "#/$defs/severity" },
        "field_path": { "$ref": "#/$defs/field_path_image" },
        "quote": {
          "type": ["string", "null"],
          "description": "OCR-фрагмент текста на картинке, если правило завязано на надпись. Иначе null."
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "card_case": {
      "type": "object",
      "required": [
        "case_id",
        "kind",
        "source",
        "generator",
        "card",
        "expected_violations",
        "expected_clean"
      ],
      "additionalProperties": false,
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1,
          "description": "Стабильный идентификатор кейса в датасете."
        },
        "kind": { "const": "card_case" },
        "source": {
          "enum": ["production", "synthetic", "hybrid"],
          "description": "production — реальная выгрузка, synthetic — полностью сгенерировано, hybrid — реальная основа + синтетическая примесь."
        },
        "generator": { "$ref": "#/$defs/generator" },
        "card": { "$ref": "product_card.schema.json" },
        "expected_violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/violation_card" }
        },
        "expected_clean": {
          "type": "boolean",
          "description": "true — эталон: нарушений нет; false — должны быть."
        },
        "notes": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "expected_clean": { "const": true } },
            "required": ["expected_clean"]
          },
          "then": {
            "properties": {
              "expected_violations": { "maxItems": 0 }
            }
          }
        },
        {
          "if": {
            "properties": { "expected_clean": { "const": false } },
            "required": ["expected_clean"]
          },
          "then": {
            "properties": {
              "expected_violations": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "image_case": {
      "type": "object",
      "required": [
        "case_id",
        "kind",
        "image_id",
        "file_path",
        "linked_card_id",
        "role",
        "source",
        "generator",
        "expected_violations",
        "expected_clean"
      ],
      "additionalProperties": false,
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "kind": { "const": "image_case" },
        "image_id": {
          "type": "string",
          "minLength": 1,
          "description": "Тот же id, что и в product_card.images[].image_id привязанной карточки."
        },
        "file_path": {
          "type": "string",
          "pattern": "^datasets/images/",
          "description": "Относительный путь от корня репо, формат .jpg/.png."
        },
        "linked_card_id": {
          "type": "string",
          "minLength": 1,
          "description": "id карточки (product_card.id), в контексте которой модерируется это фото. Обязателен: многие IMG-правила (IMG-03, IMG-04, IMG-25) осмысленны только в контексте карточки."
        },
        "role": { "enum": ["cover", "gallery"] },
        "source": { "enum": ["production", "synthetic", "hybrid"] },
        "generator": { "$ref": "#/$defs/generator" },
        "expected_violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/violation_image" }
        },
        "expected_clean": { "type": "boolean" },
        "notes": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "expected_clean": { "const": true } },
            "required": ["expected_clean"]
          },
          "then": {
            "properties": {
              "expected_violations": { "maxItems": 0 }
            }
          }
        },
        {
          "if": {
            "properties": { "expected_clean": { "const": false } },
            "required": ["expected_clean"]
          },
          "then": {
            "properties": {
              "expected_violations": { "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}
