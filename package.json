{
  "name": "ai-bench",
  "version": "0.1.0",
  "private": true,
  "description": "R&D-бенчмарк LLM-провайдеров для модерации карточек продуктов маркетплейса туристических активностей",
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test providers/*.test.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "eval:text": "promptfoo eval -c configs/card-text-moderation.yaml",
    "eval:image": "promptfoo eval -c configs/card-image-moderation.yaml",
    "view": "promptfoo view",
    "harvest:sputnik8": "tsx scripts/parse/harvest-sputnik8.ts",
    "parse:sputnik8": "tsx scripts/parse/parse-sputnik8.ts",
    "images:download": "tsx scripts/parse/download-images.ts",
    "parse:validate": "tsx scripts/parse/validate.ts",
    "parse:summary": "tsx scripts/parse/summary.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "promptfoo": "^0.121.7",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^5.7.1",
    "p-queue": "^9.1.2",
    "robots-parser": "^3.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
