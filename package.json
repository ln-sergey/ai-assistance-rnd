{
  "name": "ai-bench",
  "version": "0.1.0",
  "private": true,
  "description": "R&D-бенчмарк LLM-провайдеров для модерации карточек продуктов маркетплейса туристических активностей",
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test providers/*.test.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "eval:text": "promptfoo eval -c configs/card-text-moderation.yaml",
    "eval:image": "promptfoo eval -c configs/card-image-moderation.yaml",
    "view": "promptfoo view",
    "harvest:sputnik8": "tsx scripts/parse/harvest-sputnik8.ts",
    "harvest:pmpoperator": "tsx scripts/parse/harvest-pmpoperator.ts",
    "harvest:scantour": "tsx scripts/parse/harvest-scantour.ts",
    "harvest:afisha": "tsx scripts/parse/harvest-afisha.ts",
    "harvest:all": "pnpm harvest:sputnik8 && pnpm harvest:pmpoperator && pnpm harvest:scantour && pnpm harvest:afisha",
    "parse:sputnik8": "tsx scripts/parse/parse-sputnik8.ts",
    "parse:pmpoperator": "tsx scripts/parse/parse-pmpoperator.ts",
    "parse:scantour": "tsx scripts/parse/parse-scantour.ts",
    "parse:afisha": "tsx scripts/parse/parse-afisha.ts",
    "parse:all": "pnpm parse:sputnik8 && pnpm parse:pmpoperator && pnpm parse:scantour && pnpm parse:afisha",
    "images:download": "tsx scripts/parse/download-images.ts",
    "parse:validate": "tsx scripts/parse/validate.ts",
    "parse:summary": "tsx scripts/parse/summary.ts",
    "cards:delete": "tsx scripts/data/cards-delete.ts",
    "annotations:delete": "tsx scripts/data/annotations-delete.ts",
    "annotations:list": "tsx scripts/data/annotations-list-pending.ts",
    "annotations:scaffold": "tsx scripts/data/annotations-scaffold.ts",
    "annotations:commit": "tsx scripts/data/annotations-commit.ts",
    "cases:generate": "tsx scripts/data/cases-generate.ts",
    "rules:compact": "tsx scripts/data/build-rules-compact.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "promptfoo": "^0.121.7",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^5.7.1",
    "p-queue": "^9.1.2",
    "robots-parser": "^3.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "yaml": "^2.8.3"
  }
}
